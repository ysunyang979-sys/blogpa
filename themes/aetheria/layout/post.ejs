                  if (window.oml2dInstance) window.oml2dInstance.tips.showMessage('神经核心已上线。准备好交流了吗？', 5000, 10);

                  updateSystemPrompt();

              } catch (error) {
                  addMessage('system', `ERROR: ${error.message}`);
                  statusBadge.className = 'ai-status offline';
                  statusBadge.innerText = 'ERROR';
                  bootBtn.style.display = 'block';
                  isInitializing = false;
              }
          });
      }




      // ── 发送消息处理 ──
      const handleSend = async () => {
          const text = aiInput.value.trim();
          if (!text || !engine) return;

          aiInput.value = '';
          aiInput.disabled = true;
          sendBtn.disabled = true;

          addMessage('user', text);
          chatHistory.push({ role: "user", content: text });
          saveHistory();

          if (window.oml2dInstance) {
              window.showMascotMessage('让我想想哦~', 2000);
          }

          const replyDiv = addMessage('assistant', '<span class="ai-cursor"></span>', false);
          statusBadge.innerText = 'THINKING';

          try {
              // 构建发送给模型的消息（带裁剪）
              const messagesToSend = getTrimmedHistory();

              const chunks = await engine.chat.completions.create({
                  messages: messagesToSend,
                  temperature: 0.25,       
                  top_p: 0.95,             
                  frequency_penalty: 0.6,  
                  presence_penalty: 0.4,   
                  max_tokens: 1024,        
                  stream: true,
              });

              let reply = "";
              let lastUpdateTime = 0;
              
              for await (const chunk of chunks) {
                  const delta = chunk.choices[0]?.delta?.content || "";
                  reply += delta;
                  // 实时渲染 Markdown
                  replyDiv.innerHTML = marked.parse(reply) + '<span class="ai-cursor"></span>';
                  chatLog.scrollTop = chatLog.scrollHeight;

                  // ── 实时同步看板娘气泡 (思维流拦截) ──
                  const now = Date.now();
                  if (window.oml2dInstance && (now - lastUpdateTime > 350)) {
                      const displayLength = 15;
                      let cleanStream = reply.replace(/[\n\r\*#`]/g, ' ').trim();
                      let ticker = cleanStream.slice(-displayLength);
                      if (cleanStream.length > displayLength) ticker = "..." + ticker;
                      
                      // Alternate prefix for hacker feel
                      const prefix = Math.random() > 0.5 ? '⚡ 解析中:' : '🧠 生成中:';
                      window.showMascotMessage(`${prefix} ${ticker}`, 1000);
                      lastUpdateTime = now;
                  }
              }

              // ── 后处理：清理 1B 模型常见的输出问题 ──
              reply = cleanModelOutput(reply);
              
              replyDiv.innerHTML = marked.parse(reply);
              // 为代码块添加高亮和复制按钮
              processCodeBlocks(replyDiv);

              chatHistory.push({ role: "assistant", content: reply });
              saveHistory();
              archiveCurrentSession(); // Archive after each exchange
              
              if (window.oml2dInstance) {
                  // Make the mascot say the clean reply, truncating if too long
                  const cleanText = replyDiv.innerText.replace(/[\n\r]/g, ' ').substring(0, 40) + (replyDiv.innerText.length > 40 ? '...' : '');
                  window.showMascotMessage('✨ ' + cleanText, 6000);
              }

          } catch (error) {
              replyDiv.innerHTML = `<span style="color:var(--accent);">[ERROR: ${error.message}]</span>`;
              if (window.oml2dInstance) window.showMascotMessage('🚨 神经核心发生异常！', 4000);
          }

          statusBadge.innerText = 'ONLINE';
          aiInput.disabled = false;
          sendBtn.disabled = false;
          aiInput.focus();
                  isInitializing = false;
      };

      // ── 输出后处理器：修复 1B 模型的常见输出毛病 ──
      const cleanModelOutput = (text) => {
          if (!text) return text;
          
          // 1. 去除模型可能泄露的指令标签
          text = text.replace(/<\/?rules>/gi, '');
          text = text.replace(/<\/?article_context>/gi, '');
          text = text.replace(/<\/?examples>/gi, '');
          
          // 2. 检测并移除连续重复的段落（1B 模型的常见 bug）
          const lines = text.split('\n');
          const seen = new Set();
          const dedupedLines = [];
          for (const line of lines) {
              const trimmed = line.trim();
              if (trimmed.length === 0 || !seen.has(trimmed)) {
                  if (trimmed.length > 0) seen.add(trimmed);
                  dedupedLines.push(line);
              }
          }
          text = dedupedLines.join('\n');

          // 3. 截断过长的输出（防止模型发疯循环）
          if (text.length > 2000) {
              text = text.substring(0, 2000) + '\n\n*（回复已截断）*';
          }

          // 4. 去除模型可能输出的 "User:" 或 "Assistant:" 前缀
          text = text.replace(/^(User|Assistant|System|用户|助手|系统)\s*[:：]\s*/gim, '');

          return text.trim();
      };

      if (sendBtn && aiInput) {
          sendBtn.addEventListener('click', handleSend);
          aiInput.addEventListener('keydown', (e) => {
              if (e.key === 'Enter') {
                  e.preventDefault();
                  handleSend();
              }
          });
      }

      // ── Selection Helper Logic (划线提问) ──
      const selectionHelper = document.getElementById('ai-selection-helper');
      const askSelectionBtn = document.getElementById('ai-ask-selection-btn');
      const postContent = document.querySelector('.post-content');

      const hideHelper = () => {
          if (selectionHelper) selectionHelper.style.display = 'none';
      };

      if (postContent && selectionHelper) {
          document.addEventListener('mouseup', (e) => {
              const selection = window.getSelection();
              const selectedText = selection.toString().trim();

              if (selectedText.length > 2 && postContent.contains(e.target)) {
                  const range = selection.getRangeAt(0);
                  const rect = range.getBoundingClientRect();
                  
                  // Position helper above the selection
                  selectionHelper.style.display = 'block';
                  const helperWidth = selectionHelper.offsetWidth;
                  const helperHeight = selectionHelper.offsetHeight;
                  
                  selectionHelper.style.left = `${rect.left + (rect.width / 2) - (helperWidth / 2)}px`;
                  selectionHelper.style.top = `${rect.top - helperHeight - 10}px`;
                  
                  // Ensure it doesn't go off screen
                  if (parseFloat(selectionHelper.style.left) < 10) selectionHelper.style.left = '10px';
              } else {
                  // Only hide if we're not clicking the button itself
                  if (!e.target.closest('#ai-selection-helper')) {
                      hideHelper();
                  }
              }
          });

          askSelectionBtn.addEventListener('click', async () => {
              const selection = window.getSelection();
              const selectedText = selection.toString().trim();
              if (!selectedText) return;

              // 1. Open Panel
              if (typeof toggleAIPanel === 'function') {
                  toggleAIPanel(true);
              }
              
              // 2. Clear current input and set new prompt
              aiInput.value = `请详细解释一下文章中的这段内容：“${selectedText}”`;
              
              // 3. Ensure engine is booted
              if (!engine && bootBtn) {
                  bootBtn.click();
                  // Wait for engine to be ready before sending
                  const checkInterval = setInterval(() => {
                      if (engine && !isInitializing) {
                          clearInterval(checkInterval);
                          handleSend();
                      }
                  }, 500);
              } else {
                  handleSend();
              }
              
              hideHelper();
              selection.removeAllRanges(); // Clear selection
          });

          // Hide on scroll
          window.addEventListener('scroll', hideHelper, { passive: true });
      }

      // ── Neural Map Logic (Brain Map) ──
      const mapBtn = document.getElementById('ai-map-btn');
      const mapOverlay = document.getElementById('ai-map-overlay');
      const closeMapBtn = document.getElementById('close-map-btn');
      const downloadMapBtn = document.getElementById('download-map-btn');
      const mapContainer = document.getElementById('mermaid-container');
      const mapStatus = document.getElementById('map-status');

      if (window.mermaid) {
          window.mermaid.initialize({
              startOnLoad: false,
              theme: 'dark',
              securityLevel: 'loose',
              mindmap: { useMaxWidth: false }
          });
      }

      const generateNeuralMap = async () => {
          if (!engine) {
              if (bootBtn) bootBtn.click();
              const checkInterval = setInterval(() => {
                  if (engine && !isInitializing) {
                      clearInterval(checkInterval);
                      generateNeuralMap();
                  }
              }, 500);
              return;
          }

          mapOverlay.style.display = 'flex';
          mapStatus.innerText = 'SCANNING_NEURAL_PATHWAYS...';
          mapContainer.innerHTML = '<div class="ai-message system" style="background:transparent;border:none;">[ANALYZING_CONTENT_STRUCTURE...]</div>';

          // 预处理标题，移除可能干扰 Mermaid 的字符
          const rawTitle = document.querySelector('.main-display-title')?.innerText || 'Neural Map';
          const cleanTitle = rawTitle.replace(/[\[\]\(\)\{\}]/g, '').substring(0, 50);

          const prompt = `你现在的任务是为这篇文章生成一个 Mermaid 思维导图代码。
语法要求：
1. 必须以 "mindmap" 开头。
2. 根节点必须是：root((${cleanTitle}))。
3. 使用“空格缩进”来表示层级关系，不要使用任何箭头（如 --> 或 ->）。
4. 节点文字不要包含任何括号 [ ] ( ) { } 或引号。
5. 不要使用 - 或 * 等列表符号。
6. 只返回代码块，不要有多余解释。

示例格式：
mindmap
  root((${cleanTitle}))
    核心观点1
      细节A
      细节B
    核心观点2
`;

          let rawOutput = '';
          let mermaidCode = '';

          try {
              const response = await engine.chat.completions.create({
                  messages: [...systemMessages, { role: "user", content: prompt }],
                  temperature: 0.1, 
                  max_tokens: 1500
              });

              rawOutput = response.choices[0].message.content;
              mermaidCode = rawOutput;
              
              // 强力清洗：提取 mindmap 块并修复常见错误
              const codeBlockMatch = mermaidCode.match(/```(?:mermaid)?\s*\n([\s\S]*?)(?:\n```|$)/);
              if (codeBlockMatch) {
                  mermaidCode = codeBlockMatch[1];
              } else {
                  mermaidCode = mermaidCode.match(/mindmap[\s\S]*/)?.[0] || mermaidCode;
              }

              mermaidCode = mermaidCode.replace(/```/g, ''); // 移除可能的 Markdown 标签

              const lines = mermaidCode.split('\n');
              const cleanedLines = [];
              let mindmapStarted = false;

              for (let line of lines) {
                  if (line.trim() === 'mindmap') {
                      mindmapStarted = true;
                      cleanedLines.push('mindmap');
                      continue;
                  }
                  if (!mindmapStarted) continue;
                  
                  if (line.trim() === '') continue;
                  
                  // 启发式：如果非缩进且没有括号，可能是模型附带的对话文本（在根节点之后）
                  if (cleanedLines.length > 2 && !line.match(/^\s/) && !line.includes('(')) {
                      break; 
                  }

                  // 修复常见语法干扰
                  line = line.replace(/^(\s*)[-*+]\s+/, '$1'); // 移除 markdown 列表符
                  line = line.replace(/-->|->/g, ''); // 移除箭头
                  line = line.replace(/[\[\]]/g, ''); // 移除方括号
                  line = line.replace(/["']/g, ''); // 移除引号

                  // 移除所有圆括号和花括号，除非是 root 节点
                  if (!line.includes('root((')) {
                      line = line.replace(/[\(\)\{\}]/g, '');
                  }

                  // 压缩行内多余空格并去除尾部空格（保留行首缩进），防止 SPACELIST 解析错误
                  const indentMatch = line.match(/^\s*/);
                  const indent = indentMatch ? indentMatch[0] : '';
                  const textContent = line.substring(indent.length).trimEnd().replace(/\s{2,}/g, ' ');
                  line = indent + textContent;

                  // 跳过完全被清空的行
                  if (textContent.length === 0) continue;

                  cleanedLines.push(line);
              }
              
              mermaidCode = cleanedLines.join('\n');

              const { svg } = await window.mermaid.render('rendered-mindmap', mermaidCode.trim());
              mapContainer.innerHTML = svg;
              mapStatus.innerText = 'MAP_SYNCHRONIZED';
              if (window.lucide) window.lucide.createIcons();
          } catch (error) {
              console.error("Mermaid Render Error:", error);
              console.log("Raw AI Output:\n" + (rawOutput || 'N/A'));
              console.log("Cleaned Code:\n" + (mermaidCode || 'N/A'));
              
              mapStatus.innerText = 'ERROR: SYNTAX_RECOVERY_FAILED';
              
              const escapedRaw = (rawOutput || '').replace(/</g, '&lt;').replace(/>/g, '&gt;');
              const escapedCleaned = (mermaidCode || '').replace(/</g, '&lt;').replace(/>/g, '&gt;');
              const errorMsg = error.message || error.toString();
              
              mapContainer.innerHTML = `<div class="ai-message system" style="color:var(--accent); text-align:left; font-size: 12px; width: 100%;">
                  <div>[ERROR: 脑图语法解析失败，请重试。]</div>
                  <div style="margin-top:10px; color:#aaa;"><b>Error Detail:</b><pre style="background:rgba(0,0,0,0.5); padding:10px; white-space:pre-wrap;">${errorMsg}</pre></div>
                  <div style="margin-top:10px; color:#aaa;"><b>Parsed Code:</b><pre style="background:rgba(0,0,0,0.5); padding:10px; white-space:pre-wrap;">${escapedCleaned}</pre></div>
                  <div style="margin-top:10px; color:#aaa;"><b>Raw Output:</b><pre style="background:rgba(0,0,0,0.5); padding:10px; white-space:pre-wrap;">${escapedRaw}</pre></div>
              </div>`;
          }
      };

      const downloadMapAsPNG = () => {
          const svgElement = mapContainer.querySelector('svg');
          if (!svgElement) { alert("脑图尚未生成，无法导出。"); return; }
          
          const mapStatus = document.getElementById('map-status');
          mapStatus.innerText = 'PREPARING_EXPORT...';

          try {
              const bbox = svgElement.getBBox();
              const width = bbox.width + 100;
              const height = bbox.height + 100;
              const canvas = document.createElement('canvas');
              const scale = 2;
              canvas.width = width * scale;
              canvas.height = height * scale;
              const ctx = canvas.getContext('2d');
              const svgData = new XMLSerializer().serializeToString(svgElement);
              const svgBase64 = btoa(unescape(encodeURIComponent(svgData)));
              const img = new Image();

              img.onload = () => {
                  ctx.fillStyle = '#0a0a0a';
                  ctx.fillRect(0, 0, canvas.width, canvas.height);
                  ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
                  try {
                      const pngUrl = canvas.toDataURL('image/png');
                      const downloadLink = document.createElement('a');
                      downloadLink.href = pngUrl;
                      downloadLink.download = `NeuralMap_${Math.floor(Date.now()/1000)}.png`;
                      document.body.appendChild(downloadLink);
                      downloadLink.click();
                      document.body.removeChild(downloadLink);
                      mapStatus.innerText = 'EXPORT_SUCCESS';
                  } catch (err) {
                      mapStatus.innerText = 'SECURITY_ERR';
                      alert("由于安全限制，请右键点击脑图另存为。");
                  }
              };
              img.src = 'data:image/svg+xml;base64,' + svgBase64;
          } catch (e) {
              mapStatus.innerText = 'CRITICAL_ERR';
              alert("导出错误: " + e.message);
          }
      };

      if (mapBtn) mapBtn.addEventListener('click', generateNeuralMap);
      if (closeMapBtn) closeMapBtn.addEventListener('click', () => mapOverlay.style.display = 'none');
      if (downloadMapBtn) downloadMapBtn.addEventListener('click', downloadMapAsPNG);

      // ── AI Focus Mode Logic (Dehydrated Reading) ──
      const generateFocusSummary = async () => {
          if (!engine) {
              if (bootBtn) bootBtn.click();
              focusBtn.classList.add('loading');
              focusBtn.querySelector('span').innerText = 'INITIALIZING ENGINE...';
              
              const checkInterval = setInterval(() => {
                  if (engine && !isInitializing) {
                      clearInterval(checkInterval);
                      focusBtn.classList.remove('loading');
                      focusBtn.querySelector('span').innerText = 'DEHYDRATED READING';
                      generateFocusSummary();
                  }
              }, 500);
              return;
          }

          focusSummary.style.display = 'block';
          focusText.innerText = 'SCANNING PAGE...';
          focusFallback.style.display = 'none';
          fallbackList.innerHTML = '';
          focusBtn.classList.add('loading');
          
          // Clear previous highlights
          if (window.Mark) {
              new Mark(document.querySelector('.post-content')).unmark();
          }

          const articleTitle = document.querySelector('.main-display-title')?.innerText || '';
          const articleContent = document.querySelector('.post-content')?.innerText.substring(0, 3000) || '';

          const prompt = `你是一个精准的文本提取器。下面是文章《${articleTitle}》的正文内容：
[[CONTENT_START]]
${articleContent}
[[CONTENT_END]]
请基于上方正文生成摘要和核心句提取。

【任务规则】
1. 生成一段约140字的【摘要】，要求言简意赅。
2. 严格从原文中复制粘贴（Copy-Paste）3个最核心的句子作为【高亮】。
3. 绝对不能修改、增删或替换提取句子中的任何一个字！必须原样输出！

【输出格式】
【摘要】你的摘要内容...
【高亮】原文第一句...
【高亮】原文第二句...
【高亮】原文第三句...`;

          try {
              const chunks = await engine.chat.completions.create({
                  messages: [{ role: "system", content: "你是一个严格执行指令的文本提取专家。" }, { role: "user", content: prompt }],
                  temperature: 0.1, 
                  stream: true
              });

              let fullResponse = "";
              for await (const chunk of chunks) {
                  const delta = chunk.choices[0]?.delta?.content || "";
                  fullResponse += delta;
                  
                  // Extract summary for real-time display
                  const summaryMatch = fullResponse.match(/【摘要】([\s\S]*?)(?=【|$)/);
                  if (summaryMatch) {
                      focusText.innerText = summaryMatch[1].trim();
                  }
              }

              // Processing Highlights after stream ends
              const highlightMatches = [...fullResponse.matchAll(/【高亮】(.*?)(?=【|$)/g)];
              const sentencesToHighlight = highlightMatches.map(m => m[1].trim()).filter(s => s.length > 5);

              if (window.Mark && sentencesToHighlight.length > 0) {
                  const instance = new Mark(document.querySelector('.post-content'));
                  let foundCount = 0;

                  sentencesToHighlight.forEach(sentence => {
                      let matched = false;
                      instance.mark(sentence, {
                          element: "mark",
                          className: "neural-highlight",
                          accuracy: "complementary",
                          acrossElements: true,
                          each: () => { matched = true; }
                      });

                      if (matched) {
                          foundCount++;
                      } else {
                          // Fallback to display in panel
                          focusFallback.style.display = 'block';
                          const li = document.createElement('li');
                          li.innerText = sentence;
                          fallbackList.appendChild(li);
                      }
                  });

                  if (foundCount > 0) {
                      window.showMascotMessage(`已为你高亮 ${foundCount} 处核心内容！`, 4000);
                  }
              }
              
              if (window.lucide) window.lucide.createIcons();

          } catch (error) {
              console.error("Focus Summary Error:", error);
              focusText.innerText = "ERROR: NEURAL_CORE_FAILURE";
          } finally {
              focusBtn.classList.remove('loading');
          }
      };

      if (focusBtn) focusBtn.addEventListener('click', generateFocusSummary);
      
      const closeFocusBtn = document.getElementById('close-focus-summary');
      if (closeFocusBtn) {
          closeFocusBtn.addEventListener('click', () => {
              focusSummary.style.display = 'none';
              if (window.Mark) {
                  new Mark(document.querySelector('.post-content')).unmark();
              }
          });
      }

      // ── 初始化：为当前文章内容中的代码块添加 AI 功能 ──
      if (typeof postContent !== 'undefined' && postContent) {
          processCodeBlocks(postContent);
      }
  });
</script>