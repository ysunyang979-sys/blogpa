      // ── 轻量语法高亮引擎（纯正则，无外部依赖） ──
      const applySyntaxHighlight = (codeEl, lang) => {
          // Use innerText to get clean code, then build HTML
          let text = codeEl.innerText;
          // Initial escaping for safe HTML generation
          let html = text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

          // 1. Strings
          html = html.replace(/("[^"]*"|'[^']*'|`[^`]*`)/g, '<span class="hl-string">$1</span>');

          // 2. Comments
          html = html.replace(/(^|\n)(\s*)(#[^\n]*|\/\/[^\n]*)/g, '$1$2<span class="hl-comment">$3</span>');

          // 3. Keywords
          const keywords = 'abstract|async|await|break|case|catch|class|const|continue|debugger|default|delete|do|else|enum|export|extends|finally|for|from|function|if|import|in|instanceof|interface|let|new|of|package|private|protected|public|return|static|super|switch|this|throw|try|typeof|var|void|while|with|yield|def|elif|except|lambda|pass|raise|print|self|True|False|None|int|str|float|list|dict|tuple|set|import|from|as|global|nonlocal|with|yield|await|async';
          const kwRegex = new RegExp(`\\b(${keywords})\\b`, 'g');
          html = html.replace(kwRegex, (match, p1, offset, string) => {
              const before = string.substring(0, offset);
              const insideTag = before.lastIndexOf('<') > before.lastIndexOf('>');
              return insideTag ? match : `<span class="hl-keyword">${match}</span>`;
          });

          // 4. Numbers
          html = html.replace(/\b(\d+\.?\d*)\b/g, (match, p1, offset, string) => {
              const before = string.substring(0, offset);
              const insideTag = before.lastIndexOf('<') > before.lastIndexOf('>');
              return insideTag ? match : `<span class="hl-number">${match}</span>`;
          });

          // 5. Functions
          html = html.replace(/\b([a-zA-Z_]\w*)\s*(?=\()/g, (match, p1, offset, string) => {
              const before = string.substring(0, offset);
              const insideTag = before.lastIndexOf('<') > before.lastIndexOf('>');
              return insideTag ? p1 : `<span class="hl-function">${p1}</span>`;
          });

          codeEl.innerHTML = html;
      };

