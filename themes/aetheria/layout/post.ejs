<article id="view-post" class="view post-container">
  <canvas id="post-dna-canvas" style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: -1; opacity: 0.2; pointer-events: none; transition: opacity 1s ease;"></canvas>
  
  <script>
    (function() {
        const canvas = document.getElementById('post-dna-canvas');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        const title = "<%- page.title %>";
        
        // Seeded random based on title hash
        let hash = 0;
        for (let i = 0; i < title.length; i++) {
            hash = title.charCodeAt(i) + ((hash << 5) - hash);
        }
        const seed = Math.abs(hash);
        const hue = seed % 360;

        let w, h;
        const particles = [];
        const particleCount = 60;

        function resize() {
            w = canvas.width = window.innerWidth;
            h = canvas.height = window.innerHeight;
        }
        window.addEventListener('resize', resize);
        resize();

        class Particle {
            constructor() {
                this.init();
            }
            init() {
                this.x = Math.random() * w;
                this.y = Math.random() * h;
                this.vx = (Math.random() - 0.5) * 0.5;
                this.vy = (Math.random() - 0.5) * 0.5;
                this.size = Math.random() * 3 + 1;
                this.alpha = Math.random() * 0.5 + 0.2;
            }
            draw() {
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fillStyle = `hsla(${hue}, 70%, 60%, ${this.alpha})`;
                ctx.fill();
            }
            update() {
                this.x += this.vx;
                this.y += this.vy;
                if (this.x < 0 || this.x > w || this.y < 0 || this.y > h) this.init();
            }
        }

        for (let i = 0; i < particleCount; i++) {
            particles.push(new Particle());
        }

        function animate() {
            if (localStorage.getItem('aetheria_dna_active') === 'false') {
                canvas.style.display = 'none';
                return;
            } else {
                canvas.style.display = 'block';
            }

            ctx.clearRect(0, 0, w, h);
            
            // Draw connections (Neural web feel)
            ctx.strokeStyle = `hsla(${hue}, 70%, 60%, 0.1)`;
            ctx.lineWidth = 0.5;
            for (let i = 0; i < particles.length; i++) {
                for (let j = i + 1; j < particles.length; j++) {
                    const dx = particles[i].x - particles[j].x;
                    const dy = particles[i].y - particles[j].y;
                    const dist = Math.sqrt(dx * dx + dy * dy);
                    if (dist < 150) {
                        ctx.beginPath();
                        ctx.moveTo(particles[i].x, particles[i].y);
                        ctx.lineTo(particles[j].x, particles[j].y);
                        ctx.stroke();
                    }
                }
            }

            particles.forEach(p => {
                p.update();
                p.draw();
            });
            requestAnimationFrame(animate);
        }
        animate();
    })();
  </script>
  <div class="post-hero">
    <% if (page.cover) { %>
      <img src="<%- url_for(page.cover) %>" alt="Cover" class="hero-image" onerror="this.src='https://api.btstu.cn/sjbz/api.php?lx=dongman&format=images&rand=<%= page.title %>'">
      <div class="hero-overlay"></div>
    <% } %>
  </div>

  <header class="post-header">
    <div class="header-content container">
      <div class="badge fade-in-up" style="background: var(--accent);"><%- page.tags?.data[0]?.name || 'EDITORIAL' %></div>
      <h1 class="main-display-title fade-in-up" style="font-size: clamp(2rem, 8vw, 4.5rem); margin-top: 1rem; color: var(--text-main);"><%- page.title %></h1>
      
      <div class="post-meta fade-in-up" style="animation-delay: 0.2s;">
        <span class="meta-item"><i data-lucide="calendar"></i> <%- date(page.date, 'MMM DD, YYYY') %></span>
        <span class="meta-divider"></span>
        <span class="meta-item"><i data-lucide="clock"></i> <%- Math.ceil(page.content.length / 400) %> MIN READ</span>
        <span class="meta-divider"></span>
        <span class="meta-item" style="background: var(--primary); color: var(--bg-dark);"><i data-lucide="award"></i> ORIGINAL</span>
        <span class="meta-divider"></span>
        <button id="ai-focus-btn" class="meta-item focus-btn" title="AI Assisted Focus Reading" style="cursor: pointer; height: 100%;">
          <i data-lucide="zap"></i> <span>RAPID</span>
        </button>
      </div>

      <div id="ai-focus-summary" class="ai-focus-summary fade-in-up" style="display: none; margin: 2rem auto 0; animation-delay: 0.3s;">
        <div class="summary-header" style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.2rem;">
          <div class="summary-label" style="margin-bottom: 0;"><i data-lucide="cpu"></i> SUMMARY</div>
          <button id="close-focus-summary" class="ai-console-btn" style="width: 24px; height: 24px; box-shadow: 2px 2px 0px 0px var(--black);" title="Close Summary"><i data-lucide="x" style="width: 14px; height: 14px;"></i></button>
        </div>
        <div id="ai-focus-text" class="summary-text">[INITIALIZING NEURAL CORE...]</div>
        <div id="ai-focus-fallback" class="summary-fallback" style="display: none;">
            <div class="fallback-label">KEY TAKEAWAYS:</div>
            <ul id="fallback-list"></ul>
        </div>
      </div>
    </div>
  </header>

  <div class="post-body-wrapper">
    <!-- Left Sidebar: Meta & Action -->
    <aside class="post-sidebar-left">
        <div class="meta-sidebar-sticky">
            <div class="sidebar-label">WRITTEN BY</div>
            <div class="author-info">
                <div class="avatar-wrapper creative-avatar">
                    <img src="<%- url_for('images/avatar.jpg') %>" class="author-avatar" onerror="this.src='https://ui-avatars.com/api/?name=Aetheria&background=00d2ff&color=fff'" alt="Author Avatar">
                    <div class="avatar-scanline"></div>
                </div>
                <div class="author-text">
                    <div style="font-weight: 700; font-size: 1.05rem; color: var(--text-main);"><%- config.author %></div>
                    <div style="font-size: 0.75rem; color: var(--text-dim);">Editorial Director</div>
                </div>
            </div>
            <div class="sidebar-divider"></div>
            <div class="sidebar-label">TAGS</div>
            <div class="post-tags-list">
                <% if (page.tags && page.tags.length) { %>
                    <% page.tags.forEach(function(tag) { %>
                        <a href="<%- url_for(tag.path) %>" class="tag-link"># <%- tag.name %></a>
                    <% }) %>
                <% } else { %>
                    <span style="color: var(--text-dim); font-size: 0.8rem;">No tags</span>
                <% } %>
            </div>
            <div class="sidebar-divider"></div>
            <div class="sidebar-label">ACTIONS</div>
            <div class="action-grid">
                <button class="action-btn" id="share-post" title="Share Page"><i data-lucide="share-2"></i></button>
                <button class="action-btn" id="bookmark-post" title="Toggle Bookmark"><i data-lucide="bookmark"></i></button>
                <button class="action-btn" id="terminal-help-btn" title="Terminal Commands"><i data-lucide="terminal"></i></button>
                <button class="action-btn" id="ai-chat-btn" title="AI Assistant"><i data-lucide="bot"></i></button>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="post-content glass">
      <%- page.content %>
    </div>

    <!-- Right Sidebar: TOC & AI -->
    <aside class="post-sidebar-right">
      <div id="toc-container" class="toc-container-sticky">
        <div class="toc-title">OUTLINE</div>
        <div class="toc-wrapper">
            <%- toc(page.content, {list_number: false}) %>
        </div>
      </div>
      
      <!-- AI Panel -->
      <div id="ai-panel" class="ai-panel-container" style="display: none;">
        <div class="ai-marquee">
            <div class="ai-marquee-content">
            <span>DEVELOPER: SUNNY</span>
            <span>SYSTEM_KERNEL: SUNNY_OS</span>
            <span>AI_COGNITION: BEYOND_HUMAN</span>
            <span>SYNC_STATUS: SYNCHRONIZED</span>
            <span>NEURAL_ENGINE: CUSTOM_REVOLUTION</span>
            <span>UPTIME: 99.999%</span>
            <!-- 重复一遍以保证滚动平滑 -->
            <span>DEVELOPER: SUNNY</span>
            <span>SYSTEM_KERNEL: SUNNY_OS</span>
            <span>AI_COGNITION: BEYOND_HUMAN</span>
            <span>SYNC_STATUS: SYNCHRONIZED</span>
            <span>NEURAL_ENGINE: CUSTOM_REVOLUTION</span>
            <span>UPTIME: 99.999%</span>
            </div>
        </div>
        <div class="ai-header">
            <div class="ai-header-left">
                <div class="ai-title"><i data-lucide="cpu"></i> Platelet <span class="ai-v-tag">sunnyos</span></div>
                <div class="ai-controls-row">
                    <button id="ai-reset-btn" class="ai-console-btn" title="Reset Session"><i data-lucide="plus"></i></button>
                    <button id="ai-map-btn" class="ai-console-btn" title="Generate Neural Map"><i data-lucide="network"></i></button>
                    <button id="ai-history-btn" class="ai-console-btn" title="View History"><i data-lucide="archive"></i></button>
                    <button id="ai-code-mode-btn" class="ai-console-btn" title="Code Mode (Karpathy Guidelines)"><i data-lucide="code-xml"></i></button>
                    <button id="ai-zen-btn" class="ai-console-btn" title="Toggle Immersive Mode"><i data-lucide="maximize-2"></i></button>

                    <button id="ai-focus-mode-btn" class="ai-console-btn" title="Focus Mode (ChatGPT Style)"><i data-lucide="layout"></i></button>
                </div>
            </div>
            <div class="ai-header-right">
                <div class="ai-status-wrap">
                    <span class="ai-dot"></span>
                    <div id="ai-status" class="ai-status offline">OFFLINE</div>
                </div>
            </div>
        </div>
        <div id="ai-chat-log" class="ai-chat-log">
            <div class="ai-message system">SYSTEM: WebLLM integration ready</div>
            <button id="ai-boot-btn" class="ai-boot-btn">INITIALIZE ENGINE</button>
        </div>
        <div id="ai-history-panel" class="ai-history-panel" style="display: none;">
            <div class="ai-history-header">
                <div class="ai-history-title">ARCHIVED_SESSIONS</div>
                <button id="clear-all-history-btn" class="history-control-btn" title="Clear All History"><i data-lucide="trash-2"></i></button>
                <button id="close-history-btn" class="history-control-btn"><i data-lucide="x"></i></button>
            </div>
            <div id="history-items-container" class="history-items-container">
                <!-- History items will be injected here -->
            </div>
        </div>
        <div class="ai-input-wrapper">
            <input type="text" id="ai-input" placeholder="Query Neural Core..." disabled>
            <button id="ai-send-btn" disabled><i data-lucide="send"></i></button>
        </div>
      </div>
      
      <!-- Selection Helper Button -->
      <div id="ai-selection-helper" class="ai-selection-helper" style="display: none;">
          <button id="ai-ask-selection-btn">
              <i data-lucide="sparkles"></i>
              <span>ASK PLATELET</span>
          </button>
          <div class="helper-arrow"></div>
      </div>
    </aside>
  </div>

  <!-- Neural Map Overlay -->
  <div id="ai-map-overlay" class="ai-map-overlay" style="display: none;">
      <div class="map-toolbar">
          <div class="map-info">
              <span class="map-label">NEURAL_STRUCTURE_MAP</span>
              <span id="map-status" class="map-status">IDLE</span>
          </div>
          <div class="map-actions">
              <button id="download-artifact-btn" class="map-btn" title="Download HTML"><i data-lucide="download"></i> DOWNLOAD</button>
              <button id="close-artifact-btn" class="map-btn" title="Close"><i data-lucide="x"></i></button>
          </div>
      </div>
      <div id="mermaid-container" class="mermaid-container">
          <!-- Mermaid SVG will be rendered here -->
      </div>
      <div class="map-scanline"></div>
  </div>
</article>

<style>
  .post-hero {
    position: relative;
    width: 100%;
    height: 400px;
    background: var(--primary);
    overflow: hidden;
    border-bottom: var(--border-width) solid var(--black);
  }

  #view-post {
    max-width: 1600px;
    margin: 0 auto;
    background: var(--white);
    position: relative;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.9);
  }

  .hero-overlay {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: linear-gradient(to bottom, rgba(244, 244, 240, 0) 0%, var(--white) 100%);
    pointer-events: none;
  }

  .post-header { 
    text-align: center; 
    padding: 4rem 0 6rem; 
    background: var(--white); 
    border-bottom: var(--border-width) solid var(--black); 
    margin-bottom: 4rem; 
    margin-top: -100px; /* Pull up onto hero */
    position: relative;
    z-index: 10;
  }

  .header-content {
    background: var(--white);
    padding: 2.5rem;
    display: inline-block;
    border: var(--border-width) solid var(--black);
    box-shadow: 12px 12px 0px 0px var(--black);
    max-width: 90%;
  }

  .post-meta { display: flex; align-items: center; justify-content: center; gap: 1rem; color: var(--black); margin-top: 2rem; font-weight: 800; font-size: 0.9rem; flex-wrap: wrap; }
  .meta-item { display: flex; align-items: center; gap: 0.6rem; background: var(--white); padding: 0.4rem 1rem; border: 2px solid var(--black); box-shadow: 4px 4px 0px 0px var(--black); color: inherit; }
  .meta-item i { width: 16px; height: 16px; color: inherit; }
  .meta-divider { width: 2px; height: 20px; background: var(--black); }
  
  .post-body-wrapper { 
    display: grid; 
    grid-template-columns: 220px 1fr 240px; 
    gap: 3rem; 
    align-items: flex-start; 
    position: relative; 
    padding-bottom: 6rem;
    z-index: 5;
    transition: grid-template-columns 0.3s ease;
  }
  
  .post-body-wrapper.ai-active {
    grid-template-columns: 220px 1fr 400px;
  }
  
  /* Zen Mode (Immersive) - 2 Column Layout */
  .post-body-wrapper.ai-immersive {
    display: flex !important;
    grid-template-columns: none !important;
    gap: 4rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-immersive .post-sidebar-left {
    display: none;
  }

  .ai-immersive .post-content {
    flex: 1;
    min-width: 0;
  }

  .ai-immersive .post-sidebar-right {
    width: 500px;
    flex-shrink: 0;
    position: sticky;
    top: 100px;
  }

  .ai-immersive .ai-panel-container {
    height: 750px;
    box-shadow: 15px 15px 0px 0px var(--black);
    transition: all 0.4s var(--cubic-bezier);
  }

  /* AI Focus Mode - Full Screen Chat (ChatGPT Style) */
  body.ai-focus-mode {
      overflow: hidden !important;
      background: var(--bg-card) !important;
  }
  
  body.ai-focus-mode #navbar,
  body.ai-focus-mode footer,
  body.ai-focus-mode .post-hero,
  body.ai-focus-mode .post-header,
  body.ai-focus-mode .post-sidebar-left,
  body.ai-focus-mode .post-content,
  body.ai-focus-mode #toc-container,
  body.ai-focus-mode .ai-marquee,
  body.ai-focus-mode .noise-overlay,
  body.ai-focus-mode .floating-shapes,
  body.ai-focus-mode .sticker,
  body.ai-focus-mode #scroll-progress,
  body.ai-focus-mode #progress-container {
      display: none !important;
  }

  body.ai-focus-mode .post-body-wrapper {
      display: block !important;
      padding: 0 !important;
      margin: 0 !important;
      max-width: none !important;
      height: 100vh !important;
      background: var(--bg-card);
  }

  body.ai-focus-mode .post-sidebar-right {
      position: fixed !important;
      top: 0 !important;
      left: 0 !important;
      width: 100vw !important;
      height: 100vh !important;
      z-index: 100000 !important;
      padding: 0 !important;
      margin: 0 !important;
  }

  body.ai-focus-mode .ai-panel-container {
      height: 100vh !important;
      width: 100% !important;
      border: none !important;
      box-shadow: none !important;
      margin: 0 !important;
      display: flex !important;
      flex-direction: column !important;
      background: transparent !important;
  }

  body.ai-focus-mode .ai-header {
      padding: 1.5rem 10% !important;
      background: rgba(0, 0, 0, 0.02);
      border-bottom: 1px solid var(--glass-border);
  }

  body.ai-focus-mode .ai-chat-log {
      max-width: 900px !important;
      margin: 0 auto !important;
      width: 100% !important;
      flex: 1 !important;
      padding: 3rem 2rem !important;
      background: transparent !important;
  }

  body.ai-focus-mode .ai-input-wrapper {
      max-width: 850px !important;
      margin: 0 auto 3rem !important;
      width: calc(100% - 4rem) !important;
      background: var(--white) !important;
      border: 3px solid var(--black) !important;
      box-shadow: 10px 10px 0px 0px var(--black) !important;
      padding: 0.5rem 1rem !important;
  }

  body.ai-focus-mode #ai-input {
      font-size: 1.1rem !important;
  }

  #ai-focus-mode-btn.active {
      background: var(--accent) !important;
      color: var(--black) !important;
      box-shadow: 2px 2px 0px 0px var(--black) inset !important;
  }

  /* AI Code Block Styles (Fixed) */
  .ai-code-wrapper {
      margin: 1.5rem 0;
      border: 3px solid var(--black);
      box-shadow: 6px 6px 0px 0px var(--black);
      overflow: hidden;
      position: relative;
      background: var(--bg-card);
  }
  
  .ai-code-toolbar {
      background: var(--bg-card);
      border-bottom: 2px solid var(--black);
      padding: 0.6rem 1rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-family: var(--font-mono);
      font-size: 0.75rem;
      font-weight: 900;
      position: relative;
      z-index: 10;
  }
  
  .ai-code-lang {
      color: var(--text-muted);
      letter-spacing: 0.1em;
      text-transform: uppercase;
  }
  
  .ai-code-copy {
      background: var(--primary);
      border: 2px solid var(--black);
      padding: 0.4rem 0.8rem;
      font-family: var(--font-mono);
      font-weight: 900;
      font-size: 0.65rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 0.4rem;
      transition: all 0.2s var(--cubic-bezier);
      box-shadow: 3px 3px 0px 0px var(--black);
      color: var(--black);
      user-select: none;
      -webkit-user-select: none;
  }
  
  .ai-code-copy:hover {
      transform: translate(-1px, -1px);
      box-shadow: 4px 4px 0px 0px var(--black);
      background: var(--secondary);
  }
  
  .ai-code-copy:active {
      transform: translate(1px, 1px);
      box-shadow: 0px 0px 0px 0px var(--black);
  }

  /* Syntax Highlighting Colors (Forced) */
  .ai-code-wrapper pre code .hl-keyword { color: #ff3e8d !important; font-weight: bold !important; }
  .ai-code-wrapper pre code .hl-string { color: #00d2ff !important; }
  .ai-code-wrapper pre code .hl-comment { color: #888888 !important; font-style: italic !important; }
  .ai-code-wrapper pre code .hl-number { color: #ff9900 !important; }
  .ai-code-wrapper pre code .hl-function { color: #43ff64 !important; }

  [data-theme="hacker"] .ai-code-wrapper pre code .hl-keyword { color: #00ff41 !important; }
  [data-theme="hacker"] .ai-code-wrapper pre code .hl-string { color: #00d2ff !important; }
  [data-theme="hacker"] .ai-code-wrapper pre code .hl-comment { color: #003b00 !important; }
  
  .ai-code-wrapper pre {
      margin: 0 !important;
      padding: 1.5rem !important;
      background: #121212 !important; /* Consistent dark background */
      border: none !important;
      overflow-x: auto;
  }
  
  .ai-code-wrapper code {
      background: transparent !important;
      color: #f8f8f2 !important; /* High contrast default text */
      font-family: 'IBM Plex Mono', 'Space Mono', monospace !important;
      font-size: 0.95rem !important;
      line-height: 1.6 !important;
      border: none !important;
      padding: 0 !important;
      display: block;
  }
  
  .post-content.glass { 
    padding: 4rem; 
    border-radius: 0; 
    background: var(--bg-card);
    border: var(--border-width) solid var(--text-main);
    box-shadow: 12px 12px 0px 0px var(--text-main);
  }
  
  /* Sidebars Sticky */
  .post-sidebar-left, .post-sidebar-right { position: sticky; top: 120px; }
  .meta-sidebar-sticky, .toc-container-sticky { padding-top: 1rem; }

  .sidebar-label { font-weight: 900; font-size: 0.75rem; color: var(--bg-dark); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1.5rem; background: var(--primary); padding: 0.2rem 0.5rem; border: 2px solid var(--black); display: inline-block; transform: rotate(-1deg); }
  .sidebar-divider { height: var(--border-width); background: var(--black); margin: 2rem 0; width: 60px; }
  
  .author-info { display: flex; align-items: center; gap: 1rem; margin-top: 0.5rem; padding: 1rem; border: 2px solid var(--black); background: var(--white); box-shadow: 4px 4px 0px 0px var(--black); }
  .avatar-wrapper { 
    width: 60px; height: 60px; border-radius: 0; padding: 0;
    border: var(--border-width) solid var(--black);
    background: var(--accent);
    overflow: hidden; display: flex; align-items: center; justify-content: center;
  }
  .creative-avatar {
    position: relative;
    cursor: crosshair;
  }
  .author-avatar { 
    width: 100%; height: 100%; border-radius: 0; object-fit: cover; 
    transition: all 0.3s ease;
    filter: grayscale(0%);
  }
  .creative-avatar:hover .author-avatar {
    filter: grayscale(100%) contrast(200%) invert(100%);
    transform: scale(1.1);
  }
  .avatar-scanline {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 4px;
    background: rgba(0, 255, 255, 0.8);
    box-shadow: 0 0 10px rgba(0, 255, 255, 1);
    opacity: 0;
    pointer-events: none;
    z-index: 10;
  }
  .creative-avatar:hover .avatar-scanline {
    opacity: 1;
    animation: scan 1s linear infinite;
  }
  @keyframes scan {
    0% { top: -10%; }
    100% { top: 110%; }
  }
  .action-grid { display: flex; gap: 1rem; }
  .action-btn { 
    width: 48px; height: 48px; border-radius: 0; 
    background: var(--white); border: var(--border-width) solid var(--black); 
    color: var(--black); display: flex; align-items: center; justify-content: center; 
    cursor: pointer; transition: all 0.2s var(--cubic-bezier);
    box-shadow: 4px 4px 0px 0px var(--black);
  }
  .action-btn:hover { background: var(--secondary); transform: translate(-2px, -2px); box-shadow: 6px 6px 0px 0px var(--black); }
  .action-btn:active { transform: translate(2px, 2px); box-shadow: 0px 0px 0px 0px var(--black); }
